		"logMessage": {
			"method": "POST",
			"path": "/logMessage"
		},
		"logError": {
			"method": "POST",
			"path": "/logError"
		},
		"getTimeAndLanguage": {
			"method": "GET",
			"path": "/getTimeAndLanguage"
		}
	}
