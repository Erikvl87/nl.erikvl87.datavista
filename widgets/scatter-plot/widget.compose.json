				"en": "Show correlation (R²)",
				"nl": "Toon correlatie (R²)"
			},
			"value": false
		},
		{
			"id": "showSampleSize",
			"type": "checkbox",
			"title": {
				"en": "Show sample size (n)",
				"nl": "Toon steekproefgrootte (n)"
			},
			"value": false
		},
		{
			"id": "showRefreshCountdown",
			"type": "checkbox",
			"title": {
				"en": "Show refresh countdown",
				"nl": "Toon aftelklok"
			},
			"value": false
		},
		{
			"id": "tooltipFontSize",
			"type": "dropdown",
			"title": {
				"en": "Tooltip font size",
				"nl": "Lettergrootte tooltip"
			},
			"value": "1em",
			"values": [
				{ "id": "0.8em", "title": { "en": "Small", "nl": "Klein" } },
				{ "id": "1em", "title": { "en": "Normal", "nl": "Normaal" } },
				{ "id": "1.3em", "title": { "en": "Large", "nl": "Groot" } },
				{ "id": "1.5em", "title": { "en": "Extra large", "nl": "Extra groot" } }
